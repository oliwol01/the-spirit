7"/><column index="2" value="43"/><column index="3" value="110"/><column index="4" value="33"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="VENUES" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="0"/></sort><column_widths><column index="1" value="46"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">INSERT INTO VENUES (

    user_id,
    name,
    venue_type,
    description,
    phone,
    website_url,
    instagram_url,
    facebook_url,
    street_address,
    postal_code,
    city,
    programming_tags,
    restrictions,
    capacity,
    accessibility_features,
    price,
    cover_image,
    images,
    is_published,
    maker_message

)

VALUES (

    2,

    'Apostolisch Genootschap',

    'Church',

    'The Amsterdam-Noord community has existed since 1921, following construction by the Municipality of Amsterdam starting in 1913 north of the IJ. The place of worship was put into use on December 22, 1934. A renovation took place in 2005, preserving the original character of openness and light. The community consists of approximately 100 people and is characterized by a strong sense of togetherness. This is evident not only within our own building, where we empathize with one another, inspire one another, and are close to one another, but also in our contacts with society, of which we feel a strong part. The liberal character of this community is expressed in the way worship services and other gatherings are conducted. We also consider the youth in this regard. There is a weekly gathering into which a great deal of energy is invested. Singing and music are highly valued.',

    '0611111111',

    'https://www.apgen.nl/',

    'https://www.instagram.com/apostolisch_genootschap/',

    'https://www.facebook.com/hetApostolischGenootschap/?locale=nl_NL',

    'Clematisstraat 25',

    '1032 GB',

    'Amsterdam',

    'Theatre,Workshops,Spoken word,Rituals &amp; ceremonies',

    NULL,

    '50-100',

    'Full wheelchair access,Accessible toilets,Designated seating',

    75,

    'img/venues/apostolisch-cover.jpg',

    'img/venues/apostolisch-1.jpg,img/venues/apostolisch-2.jpg',

    1,

    'We are a community-oriented space that values openness, creativity and meaningful collaborations. We are especially keen to work on projects that bring people together and create positive impact.'

);



UPDATE VENUES
SET
    latitude = 52.39223236716689,
    longitude = 4.915119708598153
WHERE venue_id = 1;</sql><current_tab id="0"/></tab_sql></sqlb_project>
